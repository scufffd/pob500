# Solana
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_API_KEY=your_helius_key
JUPITER_API_KEY=

# Index treasury (claims / holds creator rewards you swap from)
TREASURY_PRIVATE_KEY=
INDEX_MINT=

# Distribution
SOL_RESERVE=0.02
DIST_PCT=25
MIN_HOLDER_BALANCE=1
MIN_DISTRIBUTE_SOL=0.02
PRIORITY_FEE=0.000001

# Printr Partner API (OpenAPI spec: pobindex-worker/printr-api.json)
# Default base URL is taken from servers[0] in that file if PRINTR_API_BASE is unset.
PRINTR_API_BASE=https://api-preview.printr.money/v0
# JWT from Printr (Bearer). Same value can live in printr-api.json under pobWorker.bearerToken.
PRINTR_BEARER_TOKEN=
# Legacy alias for the same token:
# PRINTR_API_KEY=

# Optional: path to OpenAPI JSON (defaults to pobindex-worker/printr-api.json)
# PRINTR_OPENAPI_PATH=

# Discovery: Printr has no “list tokens” endpoint — supply seeds via allowlist and/or Dex search.
PRINTR_ALLOWLIST_PATH=data/allowlist.example.json
# PRINTR_DISCOVERY_IDS=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp:YOURMINT,0xTelecoinHexId

# With PRINTR_BEARER_TOKEN set, DexScreener mints are merged and validated against
# Printr (non-Printr tokens are dropped — only tokens created on Printr appear).
# PRINTR_AUTO_DISCOVER=0           — disable Dex merge entirely
# PRINTR_AUTO_DISCOVER=when-empty — only merge if allowlist + DISCOVERY_IDS are empty
# Dex seed sources — override defaults for a wider / narrower net:
# PRINTR_DEX_SEARCH_QUERIES=printr,brrr,fed,meteoradbc,dyn2
# PRINTR_DEX_SCREENER_DEX_ID=       — optional: keep only one dexId (e.g. meteora)
# PRINTR_DEX_DISCOVER_CAP=120       — max unique mints probed per cycle
# PRINTR_DEX_PER_QUERY_CAP=30
# PRINTR_DEX_USE_PROFILES=1         — include DexScreener token-profiles feed
# PRINTR_DEX_USE_BOOSTS=1           — include DexScreener token-boosts feeds

# On-chain discovery: tails recent Helius-parsed txs on the Printr program
# (T8HsGYv7sMk3kTnyaRqZrbRPuntYzdh12evXBkprint) and harvests SPL mints found
# in tokenTransfers. Fastest way to pick up newly-launched Printr tokens.
# PRINTR_ONCHAIN_DISCOVER=0         — disable (default on)
# PRINTR_ONCHAIN_PAGES=5            — number of 100-tx pages per cycle
# PRINTR_ONCHAIN_CAP=200            — max unique mints harvested per cycle
# PRINTR_ONCHAIN_CURSOR_PATH=./data/onchain-cursor.json

# Stake % for POB score: share of supply in getTokenLargestAccounts that sits in
# accounts whose SPL owner authority is owned by the Printr program (T8Hs…print).
# POB_STAKE_FETCH=0           — skip stake RPC (null %, no stake points)
# POB_STAKE_MAX_POINTS=12     — max points from 0–100% staked (default 12)
# POB_STAKE_RPC_DELAY_MS=50   — delay between mints when batching getLargestAccounts

# Selection floors (USD)
POB_TOP_N=5
POB_MIN_MCAP_USD=50000
POB_MIN_VOL24H_USD=10000
POB_MIN_LIQ_USD=5000

# Snapshot JSON for the dashboard (worker writes here; UI reads)
# POBINDEX_DATA_JSON=/var/www/pobindex/public/pobindex-data.json

# Tenure DB
# TENURE_DB_PATH=./data/pobindex-tenure.sqlite
# TENURE_TIERS=[{"minDays":0,"mult":1},{"minDays":30,"mult":1.25},{"minDays":90,"mult":1.5},{"minDays":180,"mult":2}]

# Optional static server
# POBINDEX_SERVER_PORT=3050
# LISTEN_HOST=127.0.0.1

# ── pob-index-stake (custom Proof of Belief staking pool) ────────────────────
# Deploy with `anchor build && anchor deploy` from POBINDEX/staking-program,
# then paste the program ID + the POB Index mint here.
# POB_STAKE_PROGRAM_ID=
# POB_STAKE_MINT=
# When =1, runCycle swaps SOL→selected Printr mints and deposits the tokens
# into the pool's reward vaults *instead of* airdropping to INDEX_MINT holders.
# POB_STAKE_DISTRIBUTE=0
# Auto-push rewards: each `npm run loop` tick, treasury (must be pool.authority)
# calls `claim_push` so accrued tokens go to stakers' ATAs without them signing.
# Does not require POB_STAKE_DISTRIBUTE=1 — only POB_STAKE_PROGRAM_ID + POB_STAKE_MINT.
# Requires program upgrade that includes `claim_push`. Costs SOL for fees + ATA rent.
# POB_STAKE_AUTO_PUSH_CLAIMS=0
# POB_STAKE_PUSH_MIN_RAW=1
# POB_STAKE_PUSH_MAX_TX=25
# Optional: separate admin keypair for init / add-reward (defaults to TREASURY_PRIVATE_KEY)
# ADMIN_PRIVATE_KEY=
# Jupiter slippage for the worker-side reward swaps (bps)
# STAKE_SWAP_SLIPPAGE_BPS=100

# ── Airdrop basket + loop cadence (used by `npm run loop`) ───────────────────
# How often the worker re-ranks top-N Printr tokens and (if needed) registers
# new reward mints on the staking pool via add_reward_mint.
# BASKET_REFRESH_MIN=60
# Number of tokens in the active basket.
# BASKET_SIZE=5
# Comma-separated mint addresses that are ALWAYS in the basket regardless of
# their pobScore. They still occupy slots (reduce top-N by that many).
# BASKET_PINNED_MINTS=
# How often the worker swaps treasury SOL → basket tokens → deposit_rewards.
# Defaults to 10 so it matches a 10-minute outer loop (set higher if RPC-heavy).
# SPEND_INTERVAL_MIN=10
# Outer loop interval: claim (simulated first — no tx if nothing to claim) +
# sweep every tick; basket refresh + spend on their own timers.
# CYCLE_INTERVAL_MIN=10
# Random jitter added to each sleep to avoid API thundering-herd (0..1).
# CYCLE_JITTER_PCT=0.1

# ── Printr creator-fee automation (Creator Wallet mode) ──────────────────────
# 1) Set PRINTR_CLAIM_TEMPLATE_SIG to a successful *claim creator* tx signature
#    for your token. Worker replays that exact tx shape with your own fee-payer.
# 2) Set PRINTR_CLAIM_FEEPAYER_PRIVATE_KEY (or rely on TREASURY_PRIVATE_KEY).
# 3) Put creator wallets in CREATOR_WALLETS so swept SOL gets consolidated.
# PRINTR_CLAIM_TEMPLATE_SIG=
# PRINTR_CLAIM_POOL=6rgLXJPzcvmMebLUaVWvn24JbYmXFYf8H3ohky6SC4yL
# PRINTR_CLAIM_FEEPAYER_PRIVATE_KEY=
# PRINTR_CLAIM_DRY_RUN=1
# CREATOR_WALLET_PRIVATE_KEY=
# CREATOR_WALLETS=[{"label":"gfnk-creator","secretKey":"<base58>","minLamports":50000000,"bufferLamports":10000000}]
# SWEEP_MIN_LAMPORTS_SOL=0.05
# SWEEP_BUFFER_LAMPORTS_SOL=0.01

# ── Presale distribution (stake_for) ─────────────────────────────────────────
# Wallet collecting presale SOL. presale-scan.js aggregates inbound transfers
# here into `data/presale/contributions.json` (under POBINDEX_PRESALE_STATE_DIR).
POBINDEX_PRESALE_WALLET=
# RPC used only for presale SOL indexing. Defaults to RPC_URL (mainnet). For a
# devnet drill set this to the same URL as STAKE_RPC_URL (e.g. Helius devnet).
# POBINDEX_PRESALE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Optional: separate folder for contributions.json / distributed.json (e.g.
# data/presale-devnet) so a devnet rehearsal does not overwrite mainnet state.
# POBINDEX_PRESALE_STATE_DIR=data/presale-devnet
# Total POB500 raw mint units (with decimals applied) reserved for the presale
# stake pool. e.g. 10_000_000 tokens at 6 decimals → 10000000000000.
POBINDEX_PRESALE_TOKEN_TOTAL=
# Lock tier for presale stakes. One of 1, 3, 7, 14, 21, 30. (fixed 7 = 1.50× multiplier.)
POBINDEX_PRESALE_LOCK_DAYS=7
# Optional: ignore contributions below this SOL amount (dust filter).
# POBINDEX_PRESALE_MIN_SOL=0.01
# Optional: comma-separated wallets to exclude (treasury seed transfers etc.).
# POBINDEX_PRESALE_EXCLUDE=
# Optional: only count transfers between these unix timestamps.
# POBINDEX_PRESALE_START_TS=
# POBINDEX_PRESALE_END_TS=
# Optional: override stake mint decimals used by preview (normally auto-detected).
# POBINDEX_PRESALE_DECIMALS=6

# ── Presale dev-buy airdrop (alternative to stake_for distribution) ──────────
# Used by `presale:devbuy-plan` + `presale:devbuy-send`.
#
# Flow:
#   1. Take RESERVE SOL off the presale wallet for smart-contract deploy costs.
#   2. Send the rest to the dev wallet.
#   3. Dev wallet tops up with DEV_EXTRA_SOL, then executes the single launch
#      dev-buy. Record the resulting token amount (raw units).
#   4. `presale:devbuy-plan -- --tokens <raw> --mint <MINT>` writes a plan.
#   5. `presale:devbuy-send -- --live` airdrops pro-rata from dev wallet ATA.
#
# SOL (float) held back on the presale wallet before sending to dev wallet.
# POBINDEX_DEVBUY_RESERVE_SOL=2
# SOL (float) the dev wallet adds on top before the launch buy. This share of
# the dev-buy returns tokens that stay in the dev wallet.
# POBINDEX_DEVBUY_DEV_EXTRA_SOL=1
# Dev-wallet private key (JSON array or bs58). Signs the airdrop SPL transfers.
# Required for `presale:devbuy-send --live`.
# POBINDEX_DEVBUY_WALLET_PRIVATE_KEY=
# Mint being airdropped (the token the dev buy returned). Overrides mint stored
# in devbuy-plan.json. Required if plan file was written without --mint.
# POBINDEX_DEVBUY_MINT=

LOG_LEVEL=info
